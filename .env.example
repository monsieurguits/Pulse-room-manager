# Base de données
DATABASE_URL="file:./dev.db"

# Ces valeurs peuvent aussi être gérées depuis /dashboard/settings (table Settings)
# mais un fallback .env est utile pour le premier démarrage.
LOVENSE_DEVELOPER_TOKEN="votre_developer_token_lovense"
LOVENSE_CALLBACK_URL="https://votre-domaine.example.com/api/lovense/callback"
APP_DOMAIN="https://votre-domaine.example.com"
NEXT_PUBLIC_APP_URL="https://pulse-room-manager.vercel.app"

# Envoi des emails de bienvenue modèle (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="PULSEROOM <onboarding@votre-domaine.example.com>"
SUPPORT_EMAIL="monsieurguits@gmail.com"

# Premier compte propriétaire (créé automatiquement au premier login si aucun admin n'existe)
INITIAL_OWNER_EMAIL="vous@example.com"
INITIAL_OWNER_PASSWORD="changez-moi-avec-un-vrai-mot-de-passe"
INITIAL_OWNER_NAME="Votre nom"

# Port du serveur WebSocket interne (synchronisation temps réel dashboard <-> control page)
WS_PORT=4001
